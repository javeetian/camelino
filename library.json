{
  "name": "Camelino",
  "version": "0.2.0",
  "description": "Portable OCaml bytecode runtime for microcontrollers — ZAM interpreter with HAL abstraction layer. Execute standard ocamlc-generated bytecode on RP2350, ESP32, and other MCUs.",
  "keywords": ["ocaml", "bytecode", "embedded", "rp2350", "rp2040", "interpreter", "zam"],
  "repository": {
    "type": "git",
    "url": "https://github.com/javeetian/camelino"
  },
  "authors": [
    {
      "name": "tianjianwei",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "frameworks": ["arduino"],
  "platforms": ["raspberrypi", "espressif32", "nordicnrf52", "atmelsam"],
  "headers": [
    "src/Camelino.h",
    "src/core/value.h",
    "src/core/memory.h",
    "src/core/vm.h",
    "src/core/opcodes.h",
    "src/core/bytecode.h",
    "src/core/byteorder.h",
    "src/core/camelino_config.h",
    "src/core/error.h",
    "src/core/gc_roots.h",
    "src/ffi/ffi.h",
    "src/repl/repl.h",
    "src/hal/err.h",
    "src/hal/gpio.h",
    "src/hal/uart.h",
    "src/hal/time.h",
    "src/hal/analog.h",
    "src/hal/flash.h",
    "src/hal/interrupt.h",
    "src/hal/cap.h"
  ],
  "build": {
    "srcFilter": [
      "+<src/core/*.c>",
      "+<src/ffi/*.c>",
      "+<src/bindings/*.c>",
      "+<src/repl/*.c>",
      "+<platform/arduino/*.c>"
    ],
    "includeDir": "src",
    "flags": "-std=gnu99 -Wall -DCAMELINO_PLATFORM_ARDUINO"
  },
  "examples": [
    {
      "name": "Blink",
      "base": "examples/Blink",
      "files": ["Blink.ino"]
    },
    {
      "name": "REPL",
      "base": "examples/REPL",
      "files": ["REPL.ino"]
    },
    {
      "name": "Sensor",
      "base": "examples/Sensor",
      "files": ["Sensor.ino"]
    }
  ]
}
